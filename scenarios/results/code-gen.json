  "artifacts": {
    "roman.py": "def to_roman(n):\n    roman_numerals = [\n        (1000, 'M'),\n        (900, 'CM'),\n        (500, 'D'),\n        (400, 'CD'),\n        (100, 'C'),\n        (90, 'XC'),\n        (50, 'L'),\n        (40, 'XL'),\n        (10, 'X'),\n        (9, 'IX'),\n        (5, 'V'),\n        (4, 'IV'),\n        (1, 'I')\n    ]\n    result = []\n    for value, symbol in roman_numerals:\n        while n >= value:\n            result.append(symbol)\n            n -= value\n        if n == 0:\n            break\n    return ''.join(result)\n"
  }
