# --- Core ---
DATABASE_URL=postgres://postgres@127.0.0.1:5433/managed_agents
API_AUTH_TOKEN=dev-token
API_PORT=8080

# --- ModelArk (BytePlus) ---
ARK_API_KEY=
ARK_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3
ARK_MODEL=

# --- BytePlus OpenAPI (veFaaS Cloud Sandbox lifecycle) ---
BYTEPLUS_ACCESS_KEY_ID=
BYTEPLUS_SECRET_ACCESS_KEY=
BYTEPLUS_OPENAPI_HOST=open.byteplusapi.com
BYTEPLUS_REGION=ap-southeast-1
VEFAAS_SANDBOX_FUNCTION_ID=
SANDBOX_IMAGE=
SANDBOX_TIMEOUT_MINUTES=60

# --- TOS object storage ---
TOS_ENDPOINT=tos-ap-southeast-1.bytepluses.com
TOS_REGION=ap-southeast-1
TOS_BUCKET=

# --- AgentKit MCP (optional, M10) ---
AGENTKIT_MCP_URL=
AGENTKIT_MCP_API_KEY=

# --- Worker / scheduler ---
WORKER_ID=
LEASE_TTL_MS=30000
HEARTBEAT_MS=10000
POLL_MS=1000
MAX_ATTEMPTS=5
CHECKPOINT_EVERY_STEPS=5

# --- Benchmark only ---
HARNESS_ENABLE_FAULTS=0
