# --- Core ---
NODE_ENV=development
DATABASE_URL=postgres://postgres@127.0.0.1:5433/managed_agents
# Operator token → the built-in 'default' tenant. Mint per-tenant API keys with
# `npm run admin key create <tenantId>`. Production and non-loopback binding
# require an explicit deployment secret of at least 32 non-whitespace characters.
API_AUTH_TOKEN=dev-token
# Loopback by default. Set 0.0.0.0 only when the deployment network boundary is
# intentionally exposing the API.
API_HOST=127.0.0.1
API_PORT=8080
# Structured-log level: debug | info | warn | error.
LOG_LEVEL=info
# Max request body (bytes) and bounded shutdown drain (ms).
API_BODY_LIMIT_BYTES=1048576
SHUTDOWN_TIMEOUT_MS=15000
# Per-tenant rate limit: sustained req/s + burst bucket (RATE_LIMIT_PER_SEC=0 disables).
RATE_LIMIT_PER_SEC=20
RATE_LIMIT_BURST=40
# 'instance' (in-process) or 'global' (Postgres bucket shared across API nodes).
RATE_LIMIT_SCOPE=instance
# SSE event stream keep-alive + max stream duration (ms).
SSE_HEARTBEAT_MS=15000
SSE_MAX_STREAM_MS=1800000
# Cost attribution (USD per MILLION tokens; defaults = Seed-2.0-lite). See docs/COST.md.
MODEL_PRICE_INPUT_PER_MTOK=0.25
MODEL_PRICE_OUTPUT_PER_MTOK=2.0

# --- Event transport / relay (npm run relay) ---
# 'inproc' (no-op drain; consumers read the ledger via the API) or 'kafka'.
PUBLISHER=inproc
RELAY_POLL_MS=1000
RELAY_BATCH=100
# Kafka publisher (PUBLISHER=kafka). Prefer the private hostname endpoint (its
# TLS cert matches). KAFKA_SSL_REJECT_UNAUTHORIZED=0 only for a public endpoint
# that advertises brokers by IP (cert-altname mismatch).
KAFKA_BROKERS=
KAFKA_TOPIC=run_events
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_SSL=1
KAFKA_SSL_REJECT_UNAUTHORIZED=1

# --- Credential broker (memo §9.5) ---
# 'local' = encrypted Postgres store (set CREDENTIAL_ENCRYPTION_KEY, a base64
# 32-byte AES-256 key); 'kms' = BytePlus KMS (set KMS_KEYRING_NAME + KMS_KEY_NAME,
# uses BYTEPLUS_ACCESS_KEY_ID/SECRET); 'none' disables. Manage with
# `npm run admin credential …`.
CREDENTIAL_PROVIDER=none
CREDENTIAL_ENCRYPTION_KEY=
KMS_KEYRING_NAME=
KMS_KEY_NAME=

# --- ModelArk (BytePlus) ---
ARK_API_KEY=
ARK_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3
ARK_MODEL=
# Stronger model the semantic supervisor routes to when a stuck run escalates
# (memo §25). Per-agent model_policy.escalationModel overrides this default.
ESCALATION_MODEL=

# --- BytePlus OpenAPI (veFaaS Cloud Sandbox lifecycle) ---
# Long-term IAM key, or STS temp credentials synced from `bp login` with:
#   python3 scripts/refresh-creds.py
BYTEPLUS_ACCESS_KEY_ID=
BYTEPLUS_SECRET_ACCESS_KEY=
BYTEPLUS_SESSION_TOKEN=
BYTEPLUS_OPENAPI_HOST=open.byteplusapi.com
BYTEPLUS_REGION=ap-southeast-1
VEFAAS_SANDBOX_FUNCTION_ID=
SANDBOX_IMAGE=
SANDBOX_TIMEOUT_MINUTES=60
# APIG serverless gateway fronting the sandbox app (public HTTPS + Key Auth).
# Domain skips APIG discovery; the key is sent as the Authorization header.
SANDBOX_GATEWAY_DOMAIN=
SANDBOX_GATEWAY_API_KEY=

# --- TOS object storage ---
TOS_ENDPOINT=tos-ap-southeast-1.bytepluses.com
TOS_REGION=ap-southeast-1
TOS_BUCKET=

# --- Long-term memory (Phase 2) ---
# pg = Postgres (default, works out of the box) | agentkit = AgentKit/Viking
# Memory (live) | none = disable cross-run memory
MEMORY_PROVIDER=pg
# Required when MEMORY_PROVIDER=agentkit: the Viking Memory collection name
AGENTKIT_MEMORY_COLLECTION=

# --- AgentKit MCP (optional, M10) ---
AGENTKIT_MCP_URL=
AGENTKIT_MCP_API_KEY=

# --- Worker / scheduler ---
WORKER_ID=
LEASE_TTL_MS=30000
HEARTBEAT_MS=10000
POLL_MS=1000
MAX_ATTEMPTS=5
CHECKPOINT_EVERY_STEPS=5

# --- Semantic supervisor (memo §25) ---
# Watches each run for loops/stagnation and escalates (corrective note →
# stronger model → terminate) so a run cannot spin forever burning budget.
SUPERVISOR_ENABLED=1
SUPERVISOR_LOOP_THRESHOLD=3
SUPERVISOR_STAGNATION_STEPS=5
SUPERVISOR_WINDOW=8
SUPERVISOR_MAX_ESCALATIONS=2
SUPERVISOR_BUDGET_HEADROOM=0.15
# Times a failed delegated child is replaced with a fresh attempt before the
# parent resumes with the failure. 0 disables subagent replacement.
MAX_CHILD_REPLACEMENTS=1

# --- Benchmark only ---
HARNESS_ENABLE_FAULTS=0
