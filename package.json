{
  "name": "managed-agents-runtime",
  "version": "0.1.0-alpha.1",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "migrate": "tsx src/bin/migrate.ts",
    "test": "vitest run",
    "typecheck": "tsc",
    "db": "bash scripts/dev-db.sh",
    "preflight": "tsx src/bin/preflight.ts",
    "api": "tsx src/bin/api.ts",
    "worker": "tsx src/bin/worker.ts",
    "relay": "tsx src/bin/relay.ts",
    "admin": "tsx src/bin/admin.ts",
    "bench:survival": "tsx bench/survival.ts",
    "release:gate": "tsx scripts/release-gate.ts",
    "container:smoke": "tsx scripts/smoke-container.ts",
    "container:evidence": "tsx scripts/write-container-evidence.ts",
    "byteplus:sandbox:provision": "tsx scripts/provision-sandbox-application.ts",
    "byteplus:sandbox:conformance": "node --env-file=.env --import tsx scripts/conformance-runtime-sandbox.ts",
    "byteplus:sandbox:cleanup": "tsx scripts/cleanup-sandbox-application.ts",
    "release:version": "tsx scripts/check-release-version.ts"
  },
  "dependencies": {
    "@agent-infra/sandbox": "^1.0.17",
    "fastify": "^5.10.0",
    "kafkajs": "^2.2.4",
    "openai": "^6.47.0",
    "pg": "^8.22.0",
    "ulid": "^3.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
