# This committed token is only for the loopback-bound local tutorial.
# Replace it before adapting this Compose file to any shared environment.
API_AUTH_TOKEN=quickstart-only-token-change-before-shared-use-2026
API_HOST=0.0.0.0
DATABASE_URL=postgres://postgres@postgres:5432/managed_agents
HARNESS_ENABLE_FAULTS=0
HTTP_EGRESS_ALLOWLIST=https://example.com
HTTP_EGRESS_MODE=allowlist
KNOWLEDGE_PROVIDER=pg
LOCAL_OBJECT_STORE_DIR=/var/lib/managed-agents/objects
MEMORY_PROVIDER=pg
NODE_ENV=production
PUBLISHER=inproc
